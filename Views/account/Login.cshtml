@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wattmock — Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            background: #000000;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Jost', sans-serif;
        }

        .card {
            width: 420px;
            padding: 55px 50px;
        }

        .brand {
            font-family: 'Jost', sans-serif;
            font-size: 28px;
            font-weight: 500;
            letter-spacing: 6px;
            text-transform: uppercase;
            color: #c8a86a;
            margin-bottom: 45px;
        }

        .input-group {
            margin-bottom: 30px;
        }

        label {
            display: block;
            font-size: 11px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(200,168,106,0.5);
            margin-bottom: 10px;
        }

        input {
            width: 100%;
            padding: 12px 0;
            background: transparent;
            border: none;
            border-bottom: 1px solid rgba(200,168,106,0.2);
            color: #c8a86a;
            font-size: 15px;
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            outline: none;
            transition: border-color 0.3s;
        }

            input:focus {
                border-bottom-color: #c8a86a;
            }

            input::placeholder {
                color: rgba(200,168,106,0.15);
            }

        .btn {
            width: 100%;
            padding: 14px;
            margin-top: 15px;
            background: #c8a86a;
            color: #000;
            border: none;
            font-family: 'Jost', sans-serif;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 4px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
            border-radius: 2px;
        }

            .btn:hover {
                background: #d4b87a;
                letter-spacing: 6px;
            }

        .link-text {
            text-align: center;
            margin-top: 25px;
            font-size: 12px;
            color: rgba(200,168,106,0.3);
            letter-spacing: 1px;
        }

            .link-text a {
                color: rgba(200,168,106,0.6);
                text-decoration: none;
                transition: color 0.3s;
            }

                .link-text a:hover {
                    color: #c8a86a;
                }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">Wattmock</div>

        @if (ViewBag.Error != null)
        {
            <p style="color:#e05555; font-size:12px; margin-bottom:20px; letter-spacing:1px;">@ViewBag.Error</p>
        }

        <form method="post">
            <div class="input-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="input-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn">Sign In</button>
        </form>

        <p class="link-text">
            New here? <a href="/Account/Register">Begin your story</a>
        </p>
    </div>
</body>
</html>