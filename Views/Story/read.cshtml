@model Wattpadmock1.Models.Story
@{
    ViewData["Title"] = Model.Title;
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title — Wattmock</title>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        body {
            min-height: 100vh;
            background: #000000;
            font-family: 'Jost', sans-serif;
            color: #c8a86a;
        }

        .navbar {
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(200,168,106,0.1);
        }

        .brand {
            font-size: 20px;
            font-weight: 500;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: #c8a86a;
        }

        .navbar-links a {
            color: rgba(200,168,106,0.5);
            font-size: 11px;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-left: 30px;
            transition: color 0.3s;
        }

            .navbar-links a:hover {
                color: #c8a86a;
            }

        .container {
            max-width: 700px;
            margin: 60px auto;
            padding: 0 30px;
        }

        .back-link {
            display: inline-block;
            font-size: 11px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(200,168,106,0.4);
            margin-bottom: 40px;
            transition: color 0.3s;
        }

            .back-link:hover {
                color: #c8a86a;
            }

        .story-genre {
            font-size: 10px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: rgba(200,168,106,0.35);
            margin-bottom: 15px;
        }

        .story-title {
            font-size: 38px;
            font-weight: 300;
            color: #c8a86a;
            margin-bottom: 10px;
            line-height: 1.3;
        }

        .story-author {
            font-size: 11px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(200,168,106,0.35);
            margin-bottom: 50px;
            padding-bottom: 30px;
            border-bottom: 1px solid rgba(200,168,106,0.1);
        }

        .story-content {
            font-size: 16px;
            font-weight: 300;
            line-height: 2;
            color: rgba(200,168,106,0.7);
            white-space: pre-wrap;
            margin-bottom: 80px;
        }

        /* Comments section */
        .comments-section {
            border-top: 1px solid rgba(200,168,106,0.1);
            padding-top: 50px;
            margin-bottom: 80px;
        }

        .comments-title {
            font-size: 11px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: rgba(200,168,106,0.35);
            margin-bottom: 35px;
        }

        .comment {
            margin-bottom: 30px;
            padding-bottom: 30px;
            border-bottom: 1px solid rgba(200,168,106,0.06);
        }

        .comment-author {
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(200,168,106,0.5);
            margin-bottom: 8px;
        }

        .comment-content {
            font-size: 14px;
            font-weight: 300;
            color: rgba(200,168,106,0.6);
            line-height: 1.7;
        }

        /* Comment form */
        .comment-form {
            margin-top: 40px;
        }

            .comment-form textarea {
                width: 100%;
                padding: 12px 0;
                background: transparent;
                border: none;
                border-bottom: 1px solid rgba(200,168,106,0.2);
                color: #c8a86a;
                font-size: 14px;
                font-family: 'Jost', sans-serif;
                font-weight: 300;
                outline: none;
                resize: none;
                min-height: 80px;
                transition: border-color 0.3s;
            }

                .comment-form textarea:focus {
                    border-bottom-color: #c8a86a;
                }

                .comment-form textarea::placeholder {
                    color: rgba(200,168,106,0.15);
                }

        .btn {
            margin-top: 15px;
            padding: 12px 35px;
            background: #c8a86a;
            color: #000;
            border: none;
            font-family: 'Jost', sans-serif;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 4px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
            border-radius: 2px;
        }

            .btn:hover {
                background: #d4b87a;
                letter-spacing: 6px;
            }

        .no-comments {
            font-size: 12px;
            color: rgba(200,168,106,0.25);
            letter-spacing: 2px;
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a class="brand" href="/">Wattmock</a>
        <div class="navbar-links">
            <a href="/Story">Library</a>
            <a href="/Story/Create">Write</a>
            <a href="/Account/Logout">Logout</a>
        </div>
    </nav>

    <div class="container">
        <a class="back-link" href="/Story">← Back to Library</a>

        <div class="story-genre">@(Model.Genre ?? "General")</div>
        <div class="story-title">@Model.Title</div>
        <div class="story-author">by @Model.Author?.Username</div>
        <div class="story-content">@Model.Content</div>

        <!-- Comments Section -->
        <div class="comments-section">
            <div class="comments-title">Comments — @(Model.Comments?.Count ?? 0)</div>

            @if (Model.Comments == null || !Model.Comments.Any())
            {
                <p class="no-comments">No comments yet. Be the first to leave one.</p>
            }
            else
            {
                @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                {
                    <div class="comment">
                        <div class="comment-author">@comment.Author?.Username</div>
                        <div class="comment-content">@comment.Content</div>
                    </div>
                }
            }

            <!-- Comment Form -->
            <div class="comment-form">
                <form method="post" action="/Story/AddComment">
                    <input type="hidden" name="storyId" value="@Model.Id" />
                    <textarea name="content" placeholder="leave a comment..." required></textarea>
                    <button type="submit" class="btn">Post Comment</button>
                </form>
            </div>
        </div>
    </div>

</body>
</html>